# AI Provider: 'external' = Anthropic Claude, 'local' = Ollama
AI_PROVIDER=external

# Required when AI_PROVIDER=external
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# Required when AI_PROVIDER=local
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=deepseek-coder

# Password encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# App config
BACKEND_PORT=3001
FRONTEND_PORT=3000
TOTP_SECRET=your_base32_secret_here
SQLITE_PATH=./data/config.db
NODE_ENV=development